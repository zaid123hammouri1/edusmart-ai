# EduSmartAI Backend - Environment Variables Template
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./edusmart.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Model Paths
MODELS_DIR=../Saved_Models
# Optional: Override individual model paths
# OULAD_MODEL_PATH=
# AXI_MODEL_PATH=
# AXI_SCALER_PATH=

# Groq API Key for AI Chatbot (get from https://console.groq.com)
GROQ_API_KEY=
